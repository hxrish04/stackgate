# StackGate environment variables
# Copy this to .env.local and fill in your values

# Database (SQLite for local dev - no changes needed)
DATABASE_URL="file:./dev.db"

# Claude API key (for AI intake parsing)
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-YOUR_KEY_HERE"

# App
NEXT_PUBLIC_APP_NAME="StackGate"
NEXT_PUBLIC_PROVISIONING_MODE="simulation"

# Provisioning mode
# Keep these values in simulation for demos unless you intentionally want to test
# the guarded live Azure path for tiny dev-only requests.
STACKGATE_PROVISIONING_PROVIDER="simulation"
AZURE_ENABLE_LIVE_PROVISIONING="false"

# Azure live provisioning
# Only required when STACKGATE_PROVISIONING_PROVIDER="azure"
AZURE_SUBSCRIPTION_ID=""
AZURE_RESOURCE_GROUP="rg-stackgate-dev"
AZURE_LOCATION="eastus"
AZURE_POSTGRES_VERSION="16"
AZURE_CLI_PATH="C:\\Program Files\\Microsoft SDKs\\Azure\\CLI2\\wbin\\az.cmd"
