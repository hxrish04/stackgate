// StackGate Prisma Schema
// Run: npx prisma db push && npm run db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  role      String     // requester | approver | admin
  tickets   Ticket[]   @relation("Requester")
  approvals Approval[]
  createdAt DateTime   @default(now())
}

model Ticket {
  id          String               @id @default(cuid())
  requesterId String
  requester   User                 @relation("Requester", fields: [requesterId], references: [id])
  status      String               @default("Draft")
  riskLevel   String?
  costBand    String?
  autoApproved Boolean             @default(false)
  submittedAt DateTime?
  updatedAt   DateTime             @updatedAt
  createdAt   DateTime             @default(now())
  spec        TicketSpec?
  approvals   Approval[]
  events      TicketEvent[]
  job         ProvisioningJob?
  resource    ProvisionedResource?
}

model TicketSpec {
  id                    String    @id @default(cuid())
  ticketId              String    @unique
  ticket                Ticket    @relation(fields: [ticketId], references: [id])
  teamName              String?
  applicationName       String?
  environment           String?
  businessJustification String?
  requestedRegion       String?
  serverName            String?
  databaseName          String?
  adminUsername         String?
  authMode              String?   @default("password")
  computeTier           String?   @default("Burstable")
  vCores                Int?      @default(2)
  storageGb             Int?      @default(32)
  highAvailability      Boolean   @default(false)
  backupRetentionDays   Int?      @default(7)
  networkMode           String?   @default("public")
  allowedIpRanges       String?
  dataClassification    String?   @default("internal")
  destroyOnDate         String?
  notes                 String?
}

model Approval {
  id         String    @id @default(cuid())
  ticketId   String
  ticket     Ticket    @relation(fields: [ticketId], references: [id])
  approverId String?
  approver   User?     @relation(fields: [approverId], references: [id])
  stepType   String    // manager | platform
  decision   String?   // approved | rejected | pending
  comment    String?
  decidedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  type      String
  level     String   @default("info")
  message   String
  actor     String?
  createdAt DateTime @default(now())
}

model ProvisioningJob {
  id        String    @id @default(cuid())
  ticketId  String    @unique
  ticket    Ticket    @relation(fields: [ticketId], references: [id])
  mode      String    @default("simulation")
  status    String    @default("queued")
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime  @default(now())
}

model ProvisionedResource {
  id           String   @id @default(cuid())
  ticketId     String   @unique
  ticket       Ticket   @relation(fields: [ticketId], references: [id])
  resourceId   String?
  fqdn         String?
  port         Int      @default(5432)
  region       String?
  serverName   String?
  databaseName String?
  authMode     String?
  adminUsername String?
  createdAt    DateTime @default(now())
}
